APP_NAME="CareerPilot AI"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
ENVIRONMENT=development
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
JWT_SECRET_KEY="your-secret-key-here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
OLLAMA_BASE_URL="http://localhost:11434"
CORS_ORIGINS='["http://localhost:3000"]'
LOG_LEVEL="INFO"
STORAGE_PROVIDER=LOCAL
LOCAL_STORAGE_PATH=storage/resumes
MAX_FILE_SIZE_MB=5
SPACY_MODEL="en_core_web_sm"
PARSER_VERSION="v1"
MAX_PAGES=10
MAX_TEXT_LENGTH=200000

# ATS settings
ATS_MIN_SKILLS_FOR_FULL_SCORE=8
ATS_MIN_EXPERIENCE_ENTRIES=2
ATS_RECOMMENDATION_LIMIT=8

# Job Match settings
JOB_MATCH_MIN_SKILLS=5
JOB_MATCH_MAX_RECOMMENDATIONS=10
JOB_MATCH_KEYWORD_LIMIT=100
JOB_MATCH_VERSION=v1

# AI Foundation settings
AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
AI_TEMPERATURE=0.3
AI_TOP_P=0.9
AI_MAX_TOKENS=2048
AI_TIMEOUT=60
AI_RETRY_COUNT=3
PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_TTL=300
PROMPT_TEMPLATE_PATH=app/ai/prompts/templates


